<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit_salesperson_required" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.salesperson.required</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_form_view_leads"/>
        <field name="arch" type="xml">
            <!-- 
                 Note: In Odoo 18, the standard view might be referenced differently 
                 depending on exact community updates. The standard view for Leads/Opp 
                 is usually 'crm_case_form_view_leads' or 'crm_case_form_view_oppor'.
                 We target the field 'user_id' generally.
            -->
            
            <!-- Target the user_id field in the Lead section -->
            <xpath expr="//group[@invisible=&quot;type == 'opportunity'&quot;]//field[@name='user_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>

            <!-- Target the user_id field in the Opportunity section -->
            <xpath expr="//group[@invisible=&quot;type == 'lead'&quot;]//field[@name='user_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>