<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- You have been assigned email -->
    <template
        id="project_message_user_assigned"
        inherit_id="project.project_message_user_assigned"
    >
        <xpath expr="//t[@t-esc='object.display_name']" position="after">
            <span t-if="object.effective_lead_id"> of lead/opportunity <t
                t-out="object.effective_lead_id.display_name"
            /></span>
        </xpath>
    </template>

    <!-- You have been invited to follow the task -->
    <template
        id="task_invitation_follower"
        inherit_id="project.task_invitation_follower"
    >
        <xpath expr="//t[@t-out='object.display_name']" position="after">
            <span t-if="object.effective_lead_id"> of lead/opportunity <t
                t-out="object.effective_lead_id.display_name"
            /></span>
        </xpath>
    </template>
</odoo>
